pipeline {
    agent any

    environment {
        DOCKER_ORG = 'phutho1704'
        TARGET_NAMESPACE = 'dev'
        DOMAIN = 'yas-dev.local.com'
    }

    stages {
        stage('Deploy Configuration') {
            steps {
                script {
                    def ns = env.TARGET_NAMESPACE
                    sh "helm dependency build k8s/charts/yas-configuration || true"
                    sh "helm upgrade --install yas-configuration k8s/charts/yas-configuration --namespace ${ns} --create-namespace"
                }
            }
        }

        stage('Deploy UIs and BFFs') {
            steps {
                script {
                    def ns = env.TARGET_NAMESPACE
                    def domain = env.DOMAIN

                    // Deploy BFFs
                    sh """
                    helm dependency build k8s/charts/backoffice-bff || true
                    helm upgrade --install backoffice-bff k8s/charts/backoffice-bff \
                        --namespace ${ns} \
                        --set backend.ingress.host="backoffice.${domain}" \
                        --set backend.image.repository="${env.DOCKER_ORG}/yas-backoffice-bff" \
                        --set backend.image.tag="latest"
                    """

                    sh """
                    helm dependency build k8s/charts/storefront-bff || true
                    helm upgrade --install storefront-bff k8s/charts/storefront-bff \
                        --namespace ${ns} \
                        --set backend.ingress.host="storefront.${domain}" \
                        --set backend.image.repository="${env.DOCKER_ORG}/yas-storefront-bff" \
                        --set backend.image.tag="latest"
                    """

                    // Deploy UIs
                    sh """
                    helm dependency build k8s/charts/backoffice-ui || true
                    helm upgrade --install backoffice-ui k8s/charts/backoffice-ui \
                        --namespace ${ns} \
                        --set backend.image.repository="${env.DOCKER_ORG}/yas-backoffice" \
                        --set backend.image.tag="latest"
                    """

                    sh """
                    helm dependency build k8s/charts/storefront-ui || true
                    helm upgrade --install storefront-ui k8s/charts/storefront-ui \
                        --namespace ${ns} \
                        --set backend.image.repository="${env.DOCKER_ORG}/yas-storefront" \
                        --set backend.image.tag="latest"
                    """

                    // Deploy Swagger UI
                    sh """
                    helm upgrade --install swagger-ui k8s/charts/swagger-ui \
                        --namespace ${ns} \
                        --set ingress.host="api.${domain}"
                    """
                }
            }
        }

        stage('Deploy Backend Microservices') {
            steps {
                script {
                    def ns = env.TARGET_NAMESPACE
                    def domain = env.DOMAIN
                    
                    // Backend services to deploy in loop
                    def backendServices = [
                        "cart", "customer", "inventory", "location", "media", 
                        "order", "payment", "payment-paypal", "product", 
                        "promotion", "rating", "search", "tax", "recommendation", 
                        "webhook", "sampledata"
                    ]

                    for (service in backendServices) {
                        echo "Deploying backend service: ${service} with tag: latest"
                        sh "helm dependency build k8s/charts/${service} || true"
                        sh """
                        helm upgrade --install ${service} k8s/charts/${service} \
                            --namespace ${ns} \
                            --set backend.image.repository="${env.DOCKER_ORG}/yas-${service}" \
                            --set backend.image.tag="latest" \
                            --set backend.ingress.host="api.${domain}"
                        """
                    }
                }
            }
        }
    }
    post {
        success {
            echo "Successfully auto-deployed latest main code to Dev environment (namespace: dev)"
        }
    }
}
